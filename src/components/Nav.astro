---
import ThemeToggle from './ThemeToggle';
---
<header class="wrap">
  <nav class="nav" aria-label="Primary">
    <a class="brand" href="/" aria-label="Johannes Homeier - home">Johannes Homeier</a>
    <!-- min-height reserves the 32px toggle slot so the icon hydrating in
         can't shift the header height -->
    <div class="nav-links" style="min-height:32px">
      <ThemeToggle client:only="react" />
    </div>
  </nav>
</header>
