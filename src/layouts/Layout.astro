---
import '../styles/colors-and-type.css';
import '../styles/kit.css';
import '../styles/site.css';
// Self-hosted display face (replaces Google Fonts). Latin subset, weights
// that match the previous Google request.
import '@fontsource/space-grotesk/latin-400.css';
import '@fontsource/space-grotesk/latin-500.css';
import '@fontsource/space-grotesk/latin-600.css';
import '@fontsource/space-grotesk/latin-700.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Johannes Homeier', description = 'Product engineer & tech lead based in Regensburg.' } = Astro.props;
---

<!DOCTYPE html>
<html data-theme="light" data-mood="neutral" data-layout="stacked" data-palette="blush" data-experience="expand" data-typeface="system" data-bggrid="on" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <!-- Apply saved theme + local-time greeting before first paint - no flash. -->
  <script is:inline>
    (function () {
      var root = document.documentElement;
      var pref = localStorage.getItem('jh-theme') || 'auto';
      var t = pref === 'auto'
        ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
        : pref;
      root.setAttribute('data-theme', t);
      root.setAttribute('data-mood', 'neutral');
      // Reveal the greeting that matches the visitor's local hour (see .greet CSS).
      var h = new Date().getHours();
      root.setAttribute('data-daypart',
        h >= 5 && h < 10 ? 'morning' :
        h >= 10 && h < 17 ? 'day' :
        h >= 17 && h < 22 ? 'evening' : 'night');
    })();
  </script>
  <link rel="icon" href="/monogram.svg" />
  <slot name="head" />
</head>
<body>
  <slot />
  <Analytics />
  <SpeedInsights />
</body>
</html>
