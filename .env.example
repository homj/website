# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: the "from" address shown on contact notes.
# Defaults to Resend's shared onboarding@resend.dev sender.
# Set this to an address on a domain you've verified in Resend, e.g.
# CONTACT_FROM=Site Notes <notes@yourdomain.com>
# CONTACT_FROM=

# Optional: the inbox that contact notes are delivered to.
# Defaults to the site owner's address when unset.
# CONTACT_TO=you@yourdomain.com

# Friendly Captcha (https://friendlycaptcha.com) — bot prevention on the form.
# Both must be set to enforce the captcha; if either is missing it is skipped,
# which keeps local dev and previews working without secrets.
#   - PUBLIC_FRIENDLY_CAPTCHA_SITEKEY is public and shipped to the browser.
#   - FRIENDLY_CAPTCHA_API_KEY is secret and used for server-side verification.
# PUBLIC_FRIENDLY_CAPTCHA_SITEKEY=
# FRIENDLY_CAPTCHA_API_KEY=
